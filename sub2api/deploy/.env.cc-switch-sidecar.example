# CC Switch Usage Sidecar
CC_USAGE_SIDECAR_REPORT_TOKEN=change-me-to-a-long-random-token
CC_USAGE_SIDECAR_AUTO_MIGRATE=true
CC_USAGE_SIDECAR_PORT=8788

# Comma-separated source whitelist. Keep cc-switch for old clients.
# Add one value per computer when the same sub2api user uploads from multiple devices.
CC_USAGE_SIDECAR_ALLOWED_SOURCES=cc-switch,cc-switch-pc-a,cc-switch-laptop
