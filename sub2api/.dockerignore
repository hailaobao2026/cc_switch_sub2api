# =============================================================================
# Docker Ignore File for Sub2API
# =============================================================================

# Git / CI metadata
.git/
.gitignore
.gitattributes
.github/

# Notebook / editor artifacts
.ipynb_checkpoints/
**/.ipynb_checkpoints/
.idea/
.vscode/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db

# Repository docs
*.md
**/*.md

# Exclude docs by default, then restore legal docs needed by the frontend build
docs/*
docs/**
# admin-compliance gate (LegalDocumentView.vue) build-time imports
# docs/legal/*.md?raw into the frontend bundle; keep that subtree in the
# Docker build context even though docs/ is otherwise excluded.
!docs/legal/
!docs/legal/*.md

# Top-level directories not used by the Docker build
assets/
skills/
tools/

# Build artifacts
dist/
build/
**/dist/
**/build/
frontend/dist/
backend/internal/web/dist/

# Node dependencies (will be installed in container)
frontend/node_modules/
node_modules/
frontend/.pnpm-store/
frontend/.vite/

# Go build cache (will be built in container)
backend/vendor/

# Test files / reports
*_test.go
**/*_test.go
**/*.test.js
**/*.test.ts
**/*.test.tsx
**/*.spec.js
**/*.spec.ts
**/*.spec.tsx
coverage/
.nyc_output/
frontend/coverage/
frontend/src/**/__tests__/
frontend/vitest.config.ts

# Environment files
.env
.env.*
!.env.example

# Local config
config.yaml
config.local.yaml

# Logs
*.log
logs/

# Temporary files
tmp/
temp/
*.tmp

# Deploy directory: only keep the runtime entrypoint used by Dockerfile
deploy/*
deploy/**
!deploy/docker-entrypoint.sh

# Deploy/runtime local state
deploy/data/
deploy/postgres_data/
deploy/redis_data/

# GoReleaser
.goreleaser.yaml
.goreleaser.simple.yaml

# Local agent / repo helper files
.claude/
issues/
CLAUDE.md
CLA.md
DEV_GUIDE.md
README.md
README_CN.md
README_JA.md
LICENSE
Makefile
Dockerfile.goreleaser
