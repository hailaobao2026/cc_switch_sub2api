<service>
  <id>cc-usage-reporter</id>
  <name>CC Usage Reporter</name>
  <description>CC Usage Reporter background daemon</description>
  <executable>python.exe</executable>
  <arguments>-m cc_usage_reporter daemon --config "%USERPROFILE%\\.config\\cc-switch\\usage_reporter.json"</arguments>
  <log mode="roll-by-size">
    <sizeThreshold>10240</sizeThreshold>
    <keepFiles>5</keepFiles>
  </log>
  <onfailure action="restart" delay="10 sec"/>
</service>
